[Unit]
Description=Update the Cloudflare DNS record with the current public IP
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ubuntu
# The binary reads config.txt via a relative path, so run it from the project dir.
WorkingDirectory=/home/ubuntu/cf-ddns
ExecStart=/home/ubuntu/cf-ddns/cf-ddns
